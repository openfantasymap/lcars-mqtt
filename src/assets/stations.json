{
  "comms": {
    "title": "COMMS",
    "footer": "NCC-1701-G",
    "structure": {
      "sidebar": [
        {"type": "button", "height": 1, "target": {"type": "tab", "tab": "main", "label": "Hailing"}},
        {"type": "button", "height": 1, "target": {"type": "tab", "tab": "channels", "label": "Channels"}}
      ],
      "content": {
        "main": {"type": "column", "content": [
          {"type": "panel", "title": "Communications Array", "content": [
            {"type": "row", "content": [
              {"type": "readout", "label": "Frequency", "value": "141.55 MHz"},
              {"type": "readout", "label": "Channel", "value": "Alpha-7", "source": "comms/channel"},
              {"type": "indicator", "label": "Subspace Link", "state": "online"}
            ]},
            {"type": "bargraph", "values": [20, 55, 30, 72, 45, 80, 35, 62, 25, 50, 40, 68], "live": true}
          ]},
          {"type": "row", "content": [
            {"type": "button", "label": "Hail", "emit": "comms/hail"},
            {"type": "button", "label": "Open Channel", "emit": "comms/open"},
            {"type": "button", "label": "Close", "emit": "comms/close"}
          ]},
          {"type": "issues"}
        ]},
        "channels": {"type": "column", "content": [
          {"type": "panel", "title": "Subspace Channels"},
          {"type": "row", "content": [
            {"type": "toggle", "label": "Band 1", "emit": "comms/band1"},
            {"type": "toggle", "label": "Band 2", "emit": "comms/band2"},
            {"type": "toggle", "label": "Emergency", "emit": "comms/emergency"}
          ]},
          {"type": "row", "content": [
            {"type": "indicator", "label": "Starfleet", "state": "online"},
            {"type": "indicator", "label": "Distress", "state": "standby"},
            {"type": "indicator", "label": "Encrypted", "state": "offline"}
          ]}
        ]}
      }
    },
    "sources": ["comms/incoming"]
  },

  "conn": {
    "title": "CONN",
    "footer": "NCC-1701-G",
    "structure": {
      "sidebar": [
        {"type": "button", "height": 1, "target": {"type": "tab", "tab": "main", "label": "Helm"}}
      ],
      "content": {
        "main": {"type": "column", "content": [
          {"type": "panel", "title": "Helm Control", "content": [
            {"type": "row", "content": [
              {"type": "compass", "value": 45, "source": "conn/heading"},
              {"type": "column", "content": [
                {"type": "readout", "label": "Heading", "value": "045 MARK 2"},
                {"type": "readout", "label": "Velocity", "value": "Warp 6", "source": "conn/speed"},
                {"type": "nav", "emit": "conn/heading"}
              ]},
              {"type": "helm", "warp": 6, "impulse": 4, "throttle": 70}
            ]}
          ]},
          {"type": "row", "content": [
            {"type": "button", "label": "Warp 1", "emit": "conn/warp", "value": 1},
            {"type": "button", "label": "Warp 3", "emit": "conn/warp", "value": 3},
            {"type": "button", "label": "Warp 5", "emit": "conn/warp", "value": 5},
            {"type": "button", "label": "Warp 9", "emit": "conn/warp", "value": 9}
          ]},
          {"type": "row", "content": [
            {"type": "toggle", "label": "Impulse", "emit": "conn/impulse"},
            {"type": "button", "label": "Full Stop", "emit": "conn/stop"},
            {"type": "button", "label": "Engage", "emit": "conn/engage"}
          ]},
          {"type": "issues"}
        ]}
      }
    },
    "sources": ["conn/heading", "conn/speed"]
  },

  "navigation": {
    "title": "NAV",
    "footer": "NCC-1701-G",
    "structure": {
      "sidebar": [
        {"type": "button", "height": 1, "target": {"type": "tab", "tab": "main", "label": "Nav"}}
      ],
      "content": {
        "main": {"type": "column", "content": [
          {"type": "panel", "title": "Navigation", "content": [
            {"type": "row", "content": [
              {"type": "nav", "emit": "nav/course"},
              {"type": "column", "content": [
                {"type": "readout", "label": "Course", "value": "Bearing 317 M 12", "source": "nav/course"},
                {"type": "readout", "label": "Destination", "value": "Starbase 74"},
                {"type": "readout", "label": "ETA", "value": "04:12:33"},
                {"type": "button", "label": "Plot Course", "emit": "nav/plot"},
                {"type": "button", "label": "Clear", "emit": "nav/clear"}
              ]}
            ]}
          ]},
          {"type": "panel", "title": "Astrometric Charts", "content": [
            {"type": "bargraph", "values": [40, 60, 35, 75, 50, 65, 45, 70, 38, 58], "live": true}
          ]},
          {"type": "issues"}
        ]}
      }
    },
    "sources": ["nav/course"]
  },

  "bridge": {
    "title": "BRIDGE",
    "footer": "NCC-1701-G",
    "structure": {
      "sidebar": [
        {"type": "button", "height": 1, "target": {"type": "tab", "tab": "main", "label": "Command"}}
      ],
      "content": {
        "main": {"type": "column", "content": [
          {"type": "panel", "title": "Bridge — Command Overview", "content": [
            {"type": "row", "content": [
              {"type": "indicator", "label": "Shields", "state": "online"},
              {"type": "indicator", "label": "Weapons", "state": "standby"},
              {"type": "indicator", "label": "Sensors", "state": "online"},
              {"type": "indicator", "label": "Comms", "state": "online"}
            ]}
          ]},
          {"type": "stats"},
          {"type": "issues"}
        ]}
      }
    },
    "sources": []
  },

  "engineering": {
    "title": "ENGINEERING",
    "footer": "NCC-1701-G",
    "structure": {
      "sidebar": [
        {"type": "button", "height": 1, "target": {"type": "tab", "tab": "main", "label": "Systems"}},
        {"type": "button", "height": 1, "target": {"type": "tab", "tab": "power", "label": "Power"}},
        {"type": "button", "height": 1, "target": {"type": "tab", "tab": "warp", "label": "Warp Core"}}
      ],
      "content": {
        "main": {"type": "column", "content": [
          {"type": "panel", "title": "Engineering — Systems"},
          {"type": "stats", "editable": true},
          {"type": "issues"}
        ]},
        "power": {"type": "column", "content": [
          {"type": "panel", "title": "Power Routing", "content": [
            {"type": "power", "label": "Shields", "value": 85, "display": "85%", "source": "power/shields"},
            {"type": "power", "label": "Weapons", "value": 60, "state": "warning", "display": "60%", "source": "power/weapons"},
            {"type": "power", "label": "Engines", "value": 92, "display": "92%", "source": "power/engines"},
            {"type": "power", "label": "Life Support", "value": 100, "display": "100%", "source": "power/life"}
          ]},
          {"type": "row", "content": [
            {"type": "toggle", "label": "Shields", "emit": "power/shields"},
            {"type": "toggle", "label": "Weapons", "emit": "power/weapons"},
            {"type": "toggle", "label": "Engines", "emit": "power/engines"},
            {"type": "toggle", "label": "Life Support", "emit": "power/life"}
          ]}
        ]},
        "warp": {"type": "column", "content": [
          {"type": "panel", "title": "Warp Core", "content": [
            {"type": "row", "content": [
              {"type": "warpcore", "state": "running"},
              {"type": "column", "content": [
                {"type": "gauge", "label": "Core Temp", "value": 68, "unit": "%", "color": "warning", "source": "warp/temp"},
                {"type": "gauge", "label": "Antimatter", "value": 88, "unit": "%", "source": "warp/antimatter"},
                {"type": "toggle", "label": "Containment", "emit": "warp/containment"},
                {"type": "button", "label": "Eject Core", "emit": "warp/eject"}
              ]}
            ]}
          ]}
        ]}
      }
    },
    "sources": []
  },

  "transporters": {
    "title": "TRANSPORTER",
    "footer": "NCC-1701-G",
    "structure": {
      "sidebar": [
        {"type": "button", "height": 1, "target": {"type": "tab", "tab": "main", "label": "Transport"}}
      ],
      "content": {
        "main": {"type": "column", "content": [
          {"type": "panel", "title": "Transporter Control", "content": [
            {"type": "row", "content": [
              {"type": "gauge", "label": "Pattern Buffer", "value": 96, "unit": "%", "source": "transporter/buffer"},
              {"type": "column", "content": [
                {"type": "indicator", "label": "Pad Lock", "state": "standby"},
                {"type": "readout", "label": "Targets", "value": "4"},
                {"type": "readout", "label": "Confinement", "value": "Nominal"}
              ]}
            ]}
          ]},
          {"type": "row", "content": [
            {"type": "toggle", "label": "Lock", "emit": "transporter/lock"},
            {"type": "button", "label": "Scan", "emit": "transporter/scan"},
            {"type": "button", "label": "Energize", "emit": "transporter/energize"}
          ]},
          {"type": "issues"}
        ]}
      }
    },
    "sources": ["transporter/status"]
  },

  "default": {
    "title": "LCARS",
    "footer": "NCC-1701-G",
    "structure": {
      "sidebar": [
        {"type": "button", "height": 1, "target": {"type": "tab", "tab": "main", "label": "Main"}}
      ],
      "content": {
        "main": {"type": "column", "content": [
          {"type": "panel", "title": "Station"},
          {"type": "stats"},
          {"type": "issues"}
        ]}
      }
    },
    "sources": []
  }
}
